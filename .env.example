# scitex-db environment variables
#
# Copy to `.env` (or `direnv allow`) to override built-in defaults.
# Resolution precedence (highest -> lowest):
#   1. Explicit CLI flags
#   2. ./config.yaml (project-local)
#   3. $SCITEX_DB_CONFIG  (this file)
#   4. ~/.scitex/db/config.yaml (user-wide)
#   5. Built-in defaults

# Path to a YAML file overriding built-in defaults.
# SCITEX_DB_CONFIG=./config.yaml
